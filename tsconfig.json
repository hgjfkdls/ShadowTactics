{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "jsx": "react-jsx",
        "types": [
            "node"
        ],
        "paths": {
            "@shared": [
                "./src/shared/index.ts"
            ],
            "@shared/*": [
                "./src/shared/*"
            ],
            "@client/*": [
                "./src/client/*"
            ],
            "@server/*": [
                "./src/server/*"
            ]
        }
    },
    "include": [
        "src",
        "vite.config.ts",
        "src/client/main.tsx",
        "vite-env.d.ts"
    ]
}